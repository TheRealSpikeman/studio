
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isAdmin() {
      // Check if the requesting user's document in the 'users' collection has the role 'admin'.
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // USERS collection
    match /users/{userId} {
      // GET: An admin can get any user doc. A user can get their own doc.
      allow get: if isOwner(userId) || isAdmin();
      
      // LIST: Only admins can list all users.
      allow list: if isAdmin();
      
      // CREATE: A user can create their own document (e.g., on signup).
      // No one else can create a user document for someone else, except perhaps a backend process.
      allow create: if request.auth != null; // Allow any authenticated user to create their own doc during signup flow.
      
      // UPDATE: A user can update their own document. An admin can update any document.
      allow update: if isOwner(userId) || isAdmin();
      
      // DELETE: Only an admin can delete a user document.
      allow delete: if isAdmin();
    }
    
    // QUIZZES collection
    match /quizzes/{quizId} {
      // Anyone can read a published quiz.
      allow get: if resource.data.status == 'published';
      // Anyone can list published quizzes.
      allow list: if true; // Keeping this open for now for public quiz lists. Can be tightened later.
      // Only admins can create, update, or delete quizzes.
      allow create, update, delete: if isAdmin();
    }
    
    // TOOLS collection
    match /tools/{toolId} {
        // Publicly readable
        allow get, list: if true;
        // Admin-only write access
        allow create, update, delete: if isAdmin();
    }
    
    // FEATURES & SUBSCRIPTIONS (for platform configuration)
    match /features/{featureId} {
        // Publicly readable
        allow get, list: if true;
        // Admin-only write access
        allow create, update, delete: if isAdmin();
    }
    
    match /subscriptions/{subscriptionId} {
        // Publicly readable
        allow get, list: if true;
        // Admin-only write access
        allow create, update, delete: if isAdmin();
    }
    
    // USER-SPECIFIC SUBCOLLECTIONS
    match /users/{userId}/quizResults/{resultId} {
      // A user can manage their own quiz results. An admin can read them.
      allow read, write: if isOwner(userId);
      allow get, list: if isOwner(userId) || isAdmin();
    }
    
    match /users/{userId}/journalEntries/{entryId} {
      // Strict privacy: Only the owner can ever access their journal entries.
      allow read, write, delete: if isOwner(userId);
    }
  }
}
