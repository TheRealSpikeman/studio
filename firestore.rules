rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Helper Functions ---
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function hasRole(role) {
      // It's safer to check if the user document exists before accessing .data
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function canManageContent() {
        // Example: allow admin or a future 'content-manager' role
        let userRole = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
        return userRole == 'admin' || userRole == 'content-manager';
    }

    // --- User Profiles ---
    // Admins can list all users for the management dashboard
    match /users {
      allow list: if hasRole('admin');
    }

    match /users/{userId} {
      // Admins can read any user profile. Users can read their own.
      allow get: if hasRole('admin') || isOwner(userId);
      // Anyone can create their own user document when signing up.
      allow create: if request.auth.uid == userId;
      // Admins can update any profile. Users can only update their own.
      allow update: if hasRole('admin') || isOwner(userId);
      // Only admins can delete users.
      allow delete: if hasRole('admin');
    }

    // --- Public Content (Quizzes, Tools) ---
    // Anyone can read public content
    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if canManageContent();
    }
    
    match /tools/{toolId} {
      allow read: if true;
      allow write: if canManageContent();
    }
    
    match /features/{featureId} {
        allow read: if true;
        allow write: if hasRole('admin');
    }
    
     match /subscriptions/{subscriptionId} {
        allow read: if true;
        allow write: if hasRole('admin');
    }

    // --- Private User Data ---
    match /users/{userId}/{collection}/{documentId} {
      // Default deny for all subcollections
      allow read, write: if false;
    }
    
    match /users/{userId}/quizResults/{resultId} {
        allow read, write: if isOwner(userId) || hasRole('admin');
    }
    
    match /users/{userId}/journalEntries/{entryId} {
        // Strictest rule: only the user can access their journal
        allow read, write: if isOwner(userId);
    }
    
    match /users/{userId}/linkedProfessionals/{linkId} {
        allow read, write: if isOwner(userId) || hasRole('admin');
    }
  }
}
