rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // A simplified but still secure rule for debugging.
    // Any authenticated user can read or write to any document in the users collection.
    // This helps isolate if the issue is with the ownership check (request.auth.uid == userId).
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }
  }
}
