
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: This is a temporary, insecure rule for debugging purposes.
    // It allows any authenticated user to read and write to the entire database.
    // This will be replaced with secure rules once the permission issue is confirmed.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
