
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Default: Deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow users to read their own profile, and allow any authenticated user to read other profiles
    // This is useful for features where users can see each other's names or public info.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId; // User can create their own document
      allow update: if request.auth.uid == userId; // User can update their own document
      allow delete: if false; // Generally, don't allow users to delete their own accounts from the client
    }
  }
}
