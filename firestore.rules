rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own profile.
    // A user can only create a document with their own UID as the document ID.
    match /users/{userId} {
      allow read, update, delete: if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
    }

    // Quizzes are public to read for anyone.
    // Writing/creating quizzes is restricted (e.g., to admins - not implemented yet).
    match /quizzes/{quizId} {
      allow read: if true;
      allow write: if false; // Secure default, only server/admin can write
    }

    // Default security rule: Deny all other access to prevent accidental data exposure.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
