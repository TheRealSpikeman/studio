rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Alleen ingelogde gebruikers kunnen hun eigen profiel lezen, bijwerken of verwijderen.
    // De document ID ({userId}) moet exact overeenkomen met de UID van de ingelogde gebruiker.
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;

      // Een nieuwe gebruiker kan alleen een document aanmaken als de document ID
      // exact overeenkomt met zijn/haar eigen UID.
      allow create: if request.auth != null && request.resource.id == request.auth.uid;
    }
  }
}
