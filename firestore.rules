
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: DANGEROUSLY OPEN RULES FOR DEBUGGING
    // This allows absolutely anyone to read and write to your entire database.
    // This is ONLY for testing the connection and app logic.
    // We will secure this immediately after confirming it works.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
