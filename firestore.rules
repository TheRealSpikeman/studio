
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ================== HELPER FUNCTIONS ==================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      // Check if the requesting user is the owner of the document.
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRole(userId) {
      // Safely get the role of a user. Returns an empty string if not found.
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }
    
    function hasRole(role) {
        // Check if the signed-in user has a specific role.
        // Uses exists() to prevent errors on non-existent user documents (e.g., during signup).
        return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getRole(request.auth.uid) == role;
    }

    // Secure by default: deny all reads and writes unless explicitly allowed.
    match /{document=**} {
      allow read, write: if false;
    }

    // =====================================================================
    //  USERS Collection
    // =====================================================================
    match /users/{userId} {
      // ANY signed-in user can CREATE their own user document.
      allow create: if isSignedIn();

      // A user can GET their own document. An ADMIN can GET any user's document.
      allow get: if isOwner(userId) || hasRole('admin');
      
      // An ADMIN can LIST all users. Regular users cannot.
      allow list: if hasRole('admin');

      // A user can UPDATE their own document. An ADMIN can update ANY user's document.
      allow update: if isOwner(userId) || hasRole('admin');

      // An ADMIN can DELETE any user document. A user cannot delete their own account this way.
      allow delete: if hasRole('admin');
    }
    
    // =====================================================================
    //  QUIZZES Collection
    // =====================================================================
    match /quizzes/{quizId} {
      // Anyone can read a quiz.
      allow get: if true;
      // Admins can create, update, delete, and list quizzes.
      allow write, list: if hasRole('admin');
    }
    
    // =====================================================================
    //  TOOLS Collection
    // =====================================================================
    match /tools/{toolId} {
      // Anyone can read a tool's definition.
      allow get: if true;
      // Admins can create, update, delete, and list tools.
      allow write, list: if hasRole('admin');
    }
    
    // =====================================================================
    //  USER SUB-COLLECTIONS
    // =====================================================================
    match /users/{userId}/{collection}/{docId} {
      // Users can manage their own sub-collection documents. Admins can manage any.
      allow read, write, delete: if isOwner(userId) || hasRole('admin');
    }
  }
}
