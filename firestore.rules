// firestore.rules
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- TEMPORARY DIAGNOSTIC RULE ---
    // This rule allows ANYONE to read and write to ANY document.
    // It is INSECURE and for testing purposes ONLY.
    // If errors persist with this rule, the problem is NOT in the rules logic.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
