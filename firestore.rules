
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // This rule allows anyone with your Firestore database reference to view, edit,
    // and delete all data in your Firestore database. It is useful for getting
    // started, but it is configured to expire after 30 days because it
    // leaves your app open to attackers. At a minimum, you should update the
    // rules to block accidental deletions or writes from unauthorized users.
    //
    // For more information, see https://firebase.google.com/docs/rules/manage-rules
    match /{document=**} {
      allow read, write: if
          request.time < timestamp.date(2026, 6, 28);
    }
  }
}
