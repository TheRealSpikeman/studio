rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function canManageContent() {
      let userRole = getRole();
      return userRole == 'admin'; // Can add || userRole == 'content-manager' later
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- USERS Collection ---
    // User data, roles, and profiles.
    match /users/{userId} {
      // Admins can read/write/list any user profile
      allow list, write: if getRole() == 'admin';
      // Users can read/update their own profile
      allow get, update: if isOwner(userId);
    }
    
    // --- QUIZZES Collection ---
    // Contains all quiz definitions and questions.
    match /quizzes/{quizId} {
      allow read: if isSignedIn(); // Any signed-in user can read quiz definitions
      allow create, update, delete: if canManageContent();
    }
    
    // --- QUIZ RESULTS Subcollection ---
    // Stores the results for each user who takes a quiz.
    match /users/{userId}/quizResults/{resultId} {
       allow read, write, create: if isOwner(userId); // Users can manage their own results
       allow read, list: if getRole() == 'admin'; // Admins can view results for support/analysis
       // Note: Sharing with parents/coaches will require more complex rules here.
    }
    
    // --- DIARY ENTRIES Subcollection ---
    // Ultra-private journal entries.
    match /users/{userId}/diary/{entryId} {
       allow read, write, create, delete: if isOwner(userId); // Only the user can access their diary. Not even admins.
    }
    
    // --- TOOLS Collection ---
    // Definitions for tools like Focus Timer, etc.
    match /tools/{toolId} {
      allow read: if isSignedIn();
      allow create, update, delete: if canManageContent();
    }
    
    // --- FEATURES & SUBSCRIPTIONS Collections ---
    // Managed by admins only.
    match /features/{featureId} {
        allow read: if isSignedIn();
        allow create, update, delete: if getRole() == 'admin';
    }
    
    match /subscriptionPlans/{planId} {
        allow read: if isSignedIn();
        allow create, update, delete: if getRole() == 'admin';
    }
  }
}
