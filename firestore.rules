rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default: Deny all reads and writes to prevent accidental access
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Rules for the 'users' collection
    match /users/{userId} {
      // ANY authenticated user can read ANY user's profile.
      // This is common for features like showing user names/avatars.
      // For stricter privacy, you could change this to: if request.auth.uid == userId;
      allow read: if request.auth != null;
      
      // A user can ONLY create a document for themselves.
      // The document ID must match their authentication UID.
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // A user can ONLY update their own profile document.
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Disallow deletion of user profiles to maintain data integrity.
      allow delete: if false;
    }
  }
}
