rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users can be created by anyone (needed for signup)
    // but can only be read, updated, or deleted by the user themselves.
    match /users/{userId} {
      allow create;
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}