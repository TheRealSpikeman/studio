rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if a user is an admin
    function isAdmin() {
      // Assumes there's a 'users' collection where admin role is stored
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Users can read/update their own profile. Admins can read/write any profile.
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth.uid == userId; // New users can create their own doc
      allow write: if isAdmin(); // Admins have full write access (create, update, delete)
    }

    // Quizzes can be read by any authenticated user, but only written by admins.
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Tools can be read by any authenticated user, but only written by admins.
    match /tools/{toolId} {
       allow read: if isAuthenticated();
       allow write: if isAdmin();
    }

    // Subscription plans can be read by any authenticated user, but only written by admins.
    match /subscriptionPlans/{planId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // User-specific data (like quiz results, journal entries)
    // A user can only access their own data.
    match /user_data/{userId}/{collection}/{docId} {
        allow read, write: if request.auth.uid == userId || isAdmin();
    }
    
    // Feedback can be created by any authenticated user. Only admins can read/update.
    match /feedback/{feedbackId} {
        allow create: if isAuthenticated();
        allow read, update, delete: if isAdmin();
    }
  }
}
