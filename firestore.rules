
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WAARSCHUWING: Dit is een tijdelijke, onveilige regel voor debug-doeleinden.
    // Hiermee kan IEDEREEN data lezen en schrijven, zelfs zonder ingelogd te zijn.
    // Dit moet onmiddellijk worden teruggedraaid na het debuggen.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
